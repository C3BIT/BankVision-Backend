NODE_ENV=production
PORT=5094

# Database (MariaDB)
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=

# JWT Authentication
JWT_SECRET=
JWT_EXPIRATION=8h

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# LiveKit / OpenVidu
LIVEKIT_URL=wss://your-livekit-domain.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_API_URL=          # Optional: internal URL for server-to-server calls (avoids DNS hairpin)
OPENVIDU_DOMAIN=

# MinIO Storage
MINIO_ENDPOINT=http://<video-infra-server-ip>:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=https://your-api-domain.com   # Base URL for recording download links
MINIO_EGRESS_ENDPOINT=http://<video-infra-server-ip>:9000  # IP reachable by egress container for S3 uploads

# Face Recognition
FACE_PROVIDER=opencv                            # opencv | aws | mxface
OPENCV_SERVICE_URL=http://<face-service-ip>:5097
OPENCV_THRESHOLD=0.4

# Frontend URLs
CUSTOMER_PANEL_URL=https://
MANAGER_PANEL_URL=https://
ADMIN_PANEL_URL=https://

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=https://customer.yourdomain.com,https://manager.yourdomain.com,https://admin.yourdomain.com

# Email (SMTP)
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_ID=
EMAIL_PASSWORD=

# SMS OTP (sms.net.bd)
SMS_API_KEY=
SMS_API_URL=https://api.sms.net.bd/sendsms

# Cookie Security
# COOKIE_SECURE=true        # Force secure cookies (auto-set in production)
# COOKIE_DOMAIN=            # Share cookies across subdomains e.g. .yourdomain.com
